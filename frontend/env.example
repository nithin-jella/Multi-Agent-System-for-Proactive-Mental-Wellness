## ================================
## Frontend environment template
## ================================
## This file is intended as a starting point. Copy values into the repo root `.env` for Docker Compose,
## or into a local `.env.local` that is not committed.

## Two common development modes:
## 1) Direct mode (recommended): browser calls backend directly via NEXT_PUBLIC_API_URL.
## 2) Proxy mode (optional): leave NEXT_PUBLIC_API_URL empty so the frontend can use relative `/api/v1/*`.

## Direct mode (recommended)
NEXT_PUBLIC_API_URL=http://localhost:22001

## INTERNAL_API_URL is for server-side requests from Next (SSR / route handlers).
## In Docker it should typically be the service name. In production it can be the public API domain.
INTERNAL_API_URL=http://backend:22001

## NextAuth (required for auth flows)
NEXTAUTH_URL=http://localhost:22000
NEXTAUTH_SECRET=NEXTAUTH_SECRET_PLACEHOLDER
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID_PLACEHOLDER
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET_PLACEHOLDER

## Backend API access
INTERNAL_API_KEY=INTERNAL_API_KEY_PLACEHOLDER
NEXT_PUBLIC_BACKEND_BASE=http://localhost:22001
NEXT_PUBLIC_BACKEND_WS_BASE=ws://localhost:22001

# Wallet Integration (RainbowKit + WalletConnect)
# Get your Project ID from https://cloud.walletconnect.com (free)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID_HERE

# Blockchain Configuration (SOMNIA Network)
# Frontend needs NEXT_PUBLIC_ prefix for client-side access
NEXT_PUBLIC_SOMNIA_RPC_URL=https://dream-rpc.somnia.network/
NEXT_PUBLIC_CARE_TOKEN_ADDRESS=YOUR_CARE_TOKEN_ADDRESS
NEXT_PUBLIC_PLATFORM_REVENUE_ORACLE_ADDRESS=YOUR_PLATFORM_REVENUE_ORACLE_ADDRESS
NEXT_PUBLIC_CARE_STAKING_HALAL_ADDRESS=YOUR_CARE_STAKING_HALAL_ADDRESS
NEXT_PUBLIC_CARE_TOKEN_CONTROLLER_ADDRESS=YOUR_CARE_TOKEN_CONTROLLER_ADDRESS

# Runtime environment
APP_ENV=development # or production
# ============================================
# Open Campus ID (OCID) â€” OAuth / PKCE
# ============================================
# Sandbox mode requires NO client ID and NO redirect URI whitelisting.
# Set NEXT_PUBLIC_OCID_SANDBOX=false and provide a client ID only in production
# after completing the Open Campus App Whitelist Form:
# https://forms.gle/DnnOoqSG1sLjFG9KA
NEXT_PUBLIC_OCID_SANDBOX=true
NEXT_PUBLIC_OCID_CLIENT_ID=

# Full URL of the /redirect page in your deployment.
NEXT_PUBLIC_OCID_REDIRECT_URI=http://localhost:3000/redirect
